{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harness.local/schemas/tasks.schema.json",
  "title": "PlanTasks",
  "description": "Internal task list and execution state for a Harness plan. plan.md is the planning truth source; tasks.json is the execution truth source.",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "planId", "planRef", "tasks"],
  "properties": {
    "$schema": { "type": "string" },
    "planId": {
      "type": "string",
      "pattern": "^[A-Z]+-[0-9]+$",
      "examples": ["PLAN-001"]
    },
    "planRef": {
      "type": "string",
      "pattern": "^\\./plan\\.md$",
      "examples": ["./plan.md"]
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/task" }
    }
  },
  "$defs": {
    "taskId": {
      "type": "string",
      "pattern": "^[A-Z]+-[0-9]+(\\.[0-9]+)*$",
      "examples": ["TASK-001", "TASK-002.1"]
    },
    "pathList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "reviewFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "blocking", "summary"],
      "properties": {
        "severity": {
          "type": "string",
          "enum": ["critical", "important", "minor"]
        },
        "blocking": { "type": "boolean" },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "artifactRef": {
          "type": "string",
          "maxLength": 240
        },
        "recommendation": {
          "type": "string",
          "maxLength": 500
        },
        "deferReason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        }
      },
      "allOf": [
        {
          "$comment": "Critical findings are always blocking",
          "if": {
            "properties": { "severity": { "const": "critical" } },
            "required": ["severity"]
          },
          "then": {
            "properties": {
              "blocking": { "const": true }
            }
          }
        },
        {
          "$comment": "A non-blocking important finding must include a defer reason",
          "if": {
            "properties": {
              "severity": { "const": "important" },
              "blocking": { "const": false }
            },
            "required": ["severity", "blocking"]
          },
          "then": {
            "required": ["deferReason"]
          }
        },
        {
          "$comment": "Minor findings can only be non-blocking cleanup items",
          "if": {
            "properties": { "severity": { "const": "minor" } },
            "required": ["severity"]
          },
          "then": {
            "properties": {
              "blocking": { "const": false }
            }
          }
        }
      ]
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "score",
        "threshold",
        "lastResult",
        "rubricVersion",
        "checks",
        "findings",
        "reportRef"
      ],
      "properties": {
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "threshold": {
          "type": "integer",
          "const": 85
        },
        "lastResult": {
          "type": "string",
          "enum": ["not_run", "passed", "failed"]
        },
        "rubricVersion": {
          "type": "string",
          "pattern": "^review-rubric-v[0-9]+$"
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "findings": {
          "type": "array",
          "items": { "$ref": "#/$defs/reviewFinding" }
        },
        "reportRef": {
          "type": "string",
          "maxLength": 240
        }
      },
      "allOf": [
        {
          "$comment": "A passed review must meet the v1 threshold, include at least one check, and contain no blocking findings",
          "if": {
            "properties": { "lastResult": { "const": "passed" } },
            "required": ["lastResult"]
          },
          "then": {
            "properties": {
              "score": { "minimum": 85 },
              "checks": { "minItems": 1 },
              "findings": {
                "allOf": [
                  {
                    "not": {
                      "contains": {
                        "type": "object",
                        "properties": {
                          "severity": { "const": "critical" }
                        },
                        "required": ["severity"]
                      }
                    }
                  },
                  {
                    "not": {
                      "contains": {
                        "type": "object",
                        "properties": {
                          "severity": { "const": "important" },
                          "blocking": { "const": true }
                        },
                        "required": ["severity", "blocking"]
                      }
                    }
                  }
                ]
              }
            }
          }
        }
      ]
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "taskId",
        "title",
        "planSection",
        "status",
        "currentStep",
        "nextAction",
        "ownerRole",
        "dependsOn",
        "files",
        "acceptance",
        "verification",
        "review",
        "blockedReason"
      ],
      "properties": {
        "taskId": { "$ref": "#/$defs/taskId" },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "planSection": {
          "type": "string",
          "description": "Stable anchor id for the corresponding task contract section in plan.md.",
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "maxLength": 120
        },
        "status": {
          "type": "string",
          "enum": ["idle", "implementing", "testing", "reviewing", "blocked", "done"]
        },
        "currentStep": {
          "type": "string",
          "maxLength": 200
        },
        "nextAction": {
          "type": "string",
          "maxLength": 200
        },
        "ownerRole": {
          "type": "string",
          "enum": ["developer", "planner", "reviewer", "tester"]
        },
        "dependsOn": {
          "type": "array",
          "items": { "$ref": "#/$defs/taskId" },
          "uniqueItems": true
        },
        "files": {
          "type": "object",
          "additionalProperties": false,
          "required": ["create", "modify", "test"],
          "properties": {
            "create": { "$ref": "#/$defs/pathList" },
            "modify": { "$ref": "#/$defs/pathList" },
            "test": { "$ref": "#/$defs/pathList" }
          }
        },
        "acceptance": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "verification": {
          "type": "object",
          "additionalProperties": false,
          "required": ["commands", "checks", "lastResult"],
          "properties": {
            "commands": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "checks": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "lastResult": {
              "type": "string",
              "enum": ["not_run", "passed", "failed"]
            }
          }
        },
        "review": { "$ref": "#/$defs/review" },
        "blockedReason": {
          "type": "string",
          "maxLength": 500
        }
      },
      "allOf": [
        {
          "$comment": "Implementing tasks are owned by the developer",
          "if": {
            "properties": { "status": { "const": "implementing" } },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "ownerRole": { "const": "developer" }
            }
          }
        },
        {
          "$comment": "Testing tasks are owned by the tester",
          "if": {
            "properties": { "status": { "const": "testing" } },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "ownerRole": { "const": "tester" }
            }
          }
        },
        {
          "$comment": "Reviewing tasks are owned by the reviewer",
          "if": {
            "properties": { "status": { "const": "reviewing" } },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "ownerRole": { "const": "reviewer" }
            }
          }
        },
        {
          "$comment": "Blocked tasks must include a blocked reason",
          "if": {
            "properties": { "status": { "const": "blocked" } },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "blockedReason": { "type": "string", "minLength": 1 }
            }
          }
        },
        {
          "$comment": "Done tasks must have acceptance criteria, verification evidence, and passed latest verification and review results",
          "if": {
            "properties": { "status": { "const": "done" } },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "acceptance": { "type": "array", "minItems": 1 },
              "verification": {
                "properties": {
                  "lastResult": { "const": "passed" }
                },
                "anyOf": [
                  {
                    "properties": {
                      "commands": { "type": "array", "minItems": 1 }
                    }
                  },
                  {
                    "properties": {
                      "checks": { "type": "array", "minItems": 1 }
                    }
                  }
                ]
              },
              "review": {
                "properties": {
                  "lastResult": { "const": "passed" }
                }
              }
            }
          }
        }
      ]
    }
  }
}
